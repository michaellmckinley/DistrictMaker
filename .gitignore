# Data — regenerable, large (several GB of TIGER cache)
# Anchored to repo root so it doesn't shadow src/districtmaker/data/
/data/

# Outputs are tracked, but exclude debug logs and editor cruft
/outputs/.DS_Store
/outputs/*-refit*.log
/outputs/validate-*.log

# Virtual environments
.venv/
venv/
env/

# Python build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp

# Jupyter
.ipynb_checkpoints/

# Per-experiment geojson/shapefile are local-only (written by `compare
# --full-artifacts` / `validate --full-artifacts`). The committed record
# is: per-experiment png+metrics+log, plus the leader's full bundle at
# the state root.
outputs/*/experiments/*/districts.geojson
outputs/*/experiments/*/districts.shp
outputs/*/experiments/*/districts.shx
outputs/*/experiments/*/districts.dbf
outputs/*/experiments/*/districts.prj
outputs/*/experiments/*/districts.cpg

# Multi-start per-trial shapefile/geojson are also local-only — same
# rationale as the per-experiment rule above, just with the extra
# trial-NN-seed-X path layer. The trial's metrics.json, run.log, png,
# and task_result.json are small and stay tracked; the aggregates
# (_summary.md, distributions.json, best.json, _validate.log,
# _telemetry.csv) live one level up and are tracked.
outputs/*/multi-start/*/*/trial-*/districts.geojson
outputs/*/multi-start/*/*/trial-*/districts.shp
outputs/*/multi-start/*/*/trial-*/districts.shx
outputs/*/multi-start/*/*/trial-*/districts.dbf
outputs/*/multi-start/*/*/trial-*/districts.prj
outputs/*/multi-start/*/*/trial-*/districts.cpg

# Brainstorming specs are working-tree scratchpads; plans (sibling dir)
# are committed, specs are not. See memory: feedback-no-spec-in-repo.
docs/superpowers/specs/
